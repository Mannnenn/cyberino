#include <SPI.h>
#include "ICM42688.h"

// ESPr Developer S3 向けのSPIピン設定
#define SPI_SCK  12
#define SPI_MISO 13
#define SPI_MOSI 11

// IMUのCSピン（CANモジュールで10を使う想定のため、こちらは14に変更）
#define IMU_CS_PIN 20

// ICM42688オブジェクトの作成
ICM42688 IMU(SPI, IMU_CS_PIN);

// データ読み取り間隔の管理用変数
unsigned long prevIMU = 0;
const unsigned long invlIMU = 20; // 100ミリ秒間隔

void setup() {
  Serial.begin(2000000);
  
  // ネイティブUSB対応：シリアルポートの接続を待つが、PC未接続時も考慮して最大3秒で抜ける
  unsigned long t = millis();
  while(!Serial && millis() - t < 3000) {}

  // 【重要】ESP32-S3のピンを指定してSPIバスを初期化
  SPI.begin(SPI_SCK, SPI_MISO, SPI_MOSI);

  // IMUの通信開始
  int status = IMU.begin();
  if (status < 0) {
    Serial.println("IMU initialization unsuccessful");
    Serial.println("Check IMU wiring or try cycling power");
    Serial.print("Status: ");
    Serial.println(status);
    while(1) {} // 失敗した場合はここで停止
  }

    // setting the accelerometer full scale range to +/-8G
  IMU.setAccelFS(ICM42688::gpm2);
  // setting the gyroscope full scale range to +/-500 deg/s
  IMU.setGyroFS(ICM42688::dps62_5);
  
  // set output data rate to 12.5 Hz
  IMU.setAccelODR(ICM42688::odr100);
  IMU.setGyroODR(ICM42688::odr100);
  
  Serial.println("ax,ay,az,gx,gy,gz,temp_C");
}

void loop() {
  // delay()を使わず、100ms経過したときだけ処理を実行する
  if (millis() - prevIMU >= invlIMU) {
    prevIMU = millis();

    // センサーの値を読み取る
    IMU.getAGT();
    
    // データを表示する
    Serial.print(IMU.accX(), 6); Serial.print("\t");
    Serial.print(IMU.accY(), 6); Serial.print("\t");
    Serial.print(IMU.accZ(), 6); Serial.print("\t");
    Serial.print(IMU.gyrX(), 6); Serial.print("\t");
    Serial.print(IMU.gyrY(), 6); Serial.print("\t");
    Serial.print(IMU.gyrZ(), 6); Serial.print("\t");
    Serial.println(IMU.temp(), 6);
  }

  // ※ 今後、ここ（if文の外）にCANモジュールの受信処理などを記述すれば、
  // センサーの待ち時間に影響されず、スムーズに両方の処理が回ります。
}